[input_devices]

pointing/emulate_touch_from_mouse=true

[layer_names]

2d_render/layer_1="background"
2d_render/layer_2="game"
2d_render/layer_3="vfx"
2d_render/layer_4="hud"

[rendering]

renderer/rendering_method="mobile"
textures/vram_compression/import_etc2_astc=true
environment/defaults/default_clear_color=Color(0.03, 0.025, 0.04, 1)
